{
  "name": "@gilligantechinc/claude-memory-rag",
  "version": "0.3.0",
  "description": "Claude Memory RAG — pure SQLite hybrid RAG MCP server for AI coding agents. FTS5 plus optional local Ollama embeddings. Formerly @gilligan-tech/local-rag-mcp.",
  "type": "module",
  "bin": {
    "claude-memory-rag": "dist/cli.js",
    "local-rag-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepack": "node -e \"try{require('fs').chmodSync('dist/cli.js',0o755)}catch(e){}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rag",
    "mcp",
    "sqlite",
    "fts5",
    "ollama",
    "vector-search",
    "sqlite-vec",
    "pdf",
    "claude",
    "codex",
    "vscode",
    "model-context-protocol"
  ],
  "author": "Gilligan Tech Inc.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gilligan-Tech-Inc/local-rag-mcp.git"
  },
  "homepage": "https://gilligantechinc.com/",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "unpdf": "^1.6.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.9"
  }
}
